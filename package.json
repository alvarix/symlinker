{
  "name": "symlinker",
  "version": "0.1.0",
  "description": "Move files/folders to another location and symlink them back. Built for shuttling docs into an Obsidian vault while leaving symlinks in your dev repos.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node test/linker.test.js",
    "dist": "electron-builder --mac"
  },
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "dev.alvarsirlin.symlinker",
    "productName": "Symlinker",
    "mac": {
      "icon": "avatar-cat-koan.icns",
      "category": "public.app-category.productivity",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ]
    },
    "files": [
      "main.js",
      "preload.js",
      "lib/**",
      "renderer/**",
      "package.json"
    ]
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^26.8.1"
  }
}
